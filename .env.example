# Only bootstrap credentials needed on host — app fetches the rest from Infisical at boot
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_ENV=prod

# Auth0 (backend reads these from Infisical in prod, set locally for dev)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://hr-compliance-api
